# Automated Fuel Dispensing System - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://username:password@localhost:5432/fuel_system"

# Individual PostgreSQL connection parameters (alternative to DATABASE_URL)
PGHOST="localhost"
PGPORT="5432"
PGDATABASE="fuel_system"
PGUSER="your_username"
PGPASSWORD="your_password"

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Application environment (development, production, test)
NODE_ENV="development"

# Server port (defaults to 5000 if not specified)
PORT="5000"

# Session secret key for secure session management
# Generate a secure random string for production
# Example: openssl rand -base64 32
SESSION_SECRET="your-super-secret-session-key-change-this-in-production"

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS origins (comma-separated list for production)
# CORS_ORIGINS="https://yourdomain.com,https://www.yourdomain.com"

# Trusted proxy count (for deployment behind reverse proxy)
# TRUSTED_PROXY_COUNT="1"

# =============================================================================
# PAYMENT SYSTEM CONFIGURATION
# =============================================================================

# PromptPay configuration (for QR code generation)
# PROMPTPAY_ID="your-promptpay-id"

# Payment validation settings
# PAYMENT_TIMEOUT_SECONDS="300"
# PAYMENT_POLLING_INTERVAL_MS="3000"

# =============================================================================
# HARDWARE INTEGRATION
# =============================================================================

# Hardware controller settings
# HARDWARE_SIMULATION_MODE="true"
# PUMP_COUNT="3"
# DEFAULT_FLOW_RATE="45.2"

# WebSocket configuration
# WS_HEARTBEAT_INTERVAL="30000"
# WS_CONNECTION_TIMEOUT="10000"

# =============================================================================
# PERFORMANCE & MONITORING
# =============================================================================

# API polling optimization
# ACTIVE_PUMP_POLL_INTERVAL="1000"
# IDLE_PUMP_POLL_INTERVAL="5000"
# ERROR_BACKOFF_MAX_DELAY="30000"

# Caching configuration
# CACHE_TTL_SECONDS="300"
# STATIC_CACHE_MAX_AGE="31536000"

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================

# Debug logging (use for development only)
# DEBUG="express:*,hardware:*"

# Log level (error, warn, info, debug)
# LOG_LEVEL="info"

# =============================================================================
# FUEL PRICING CONFIGURATION
# =============================================================================

# Default fuel prices (in THB per liter)
# GASOHOL_95_PRICE="35.50"
# GASOHOL_91_PRICE="33.50"
# DIESEL_PRICE="32.00"
# PREMIUM_PRICE="38.00"

# Minimum and maximum fuel amounts (in THB)
# MIN_FUEL_AMOUNT="50"
# MAX_FUEL_AMOUNT="5000"

# =============================================================================
# NOTIFICATION SYSTEM
# =============================================================================

# Email configuration (for admin notifications)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# ADMIN_EMAIL="admin@yourcompany.com"

# SMS configuration (for customer notifications)
# SMS_API_KEY="your-sms-api-key"
# SMS_SENDER_ID="FuelSystem"

# =============================================================================
# ANALYTICS & REPORTING
# =============================================================================

# Analytics configuration
# ANALYTICS_ENABLED="true"
# ANALYTICS_API_KEY="your-analytics-key"

# Business intelligence
# DAILY_REPORT_TIME="23:59"
# WEEKLY_REPORT_DAY="sunday"
# MONTHLY_REPORT_DATE="1"

# =============================================================================
# MAINTENANCE & BACKUP
# =============================================================================

# Backup configuration
# BACKUP_ENABLED="true"
# BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
# BACKUP_RETENTION_DAYS="30"
# BACKUP_S3_BUCKET="your-backup-bucket"

# Maintenance windows
# MAINTENANCE_START_TIME="02:00"
# MAINTENANCE_END_TIME="04:00"
# MAINTENANCE_TIMEZONE="Asia/Bangkok"

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Development tools (set to false in production)
# ENABLE_DEV_TOOLS="true"
# ENABLE_HOT_RELOAD="true"
# ENABLE_SOURCE_MAPS="true"

# Mock data settings
# USE_MOCK_HARDWARE="true"
# USE_MOCK_PAYMENT="true"
# MOCK_PAYMENT_DELAY_MS="5000"

# =============================================================================
# PRODUCTION DEPLOYMENT
# =============================================================================

# Production optimization
# ENABLE_COMPRESSION="true"
# ENABLE_RATE_LIMITING="true"
# RATE_LIMIT_REQUESTS_PER_MINUTE="100"

# SSL/TLS configuration
# FORCE_HTTPS="true"
# SSL_CERT_PATH="/path/to/ssl/cert.pem"
# SSL_KEY_PATH="/path/to/ssl/key.pem"

# Health check endpoints
# HEALTH_CHECK_ENABLED="true"
# HEALTH_CHECK_PATH="/health"

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# QR Code service
# QR_CODE_SERVICE_URL="https://api.qrserver.com"
# QR_CODE_SIZE="300x300"
# QR_CODE_FORMAT="PNG"

# Weather service (for environmental monitoring)
# WEATHER_API_KEY="your-weather-api-key"
# WEATHER_LOCATION="Bangkok,TH"

# =============================================================================
# EXAMPLE PRODUCTION VALUES
# =============================================================================

# Example production configuration (uncomment and modify):
# DATABASE_URL="postgresql://fuel_user:secure_password@prod-db:5432/fuel_production"
# NODE_ENV="production"
# PORT="8080"
# SESSION_SECRET="randomly-generated-64-character-secret-key-for-production"
# CORS_ORIGINS="https://fuel.yourcompany.com"
# TRUSTED_PROXY_COUNT="1"
# LOG_LEVEL="warn"
# ENABLE_COMPRESSION="true"
# FORCE_HTTPS="true"

# =============================================================================
# SECURITY NOTES
# =============================================================================

# IMPORTANT SECURITY CONSIDERATIONS:
# 
# 1. NEVER commit the actual .env file to version control
# 2. Use strong, unique passwords for all accounts
# 3. Generate a cryptographically secure SESSION_SECRET
# 4. Use environment-specific database credentials
# 5. Enable HTTPS in production
# 6. Restrict CORS origins to your domain only
# 7. Use secrets management in production (AWS Secrets Manager, etc.)
# 8. Rotate secrets regularly
# 9. Monitor for unauthorized access
# 10. Use read-only database users where possible

# =============================================================================
# GETTING STARTED
# =============================================================================

# Quick setup for development:
# 1. Copy this file to .env
# 2. Set up a PostgreSQL database
# 3. Update DATABASE_URL with your database connection
# 4. Generate a SESSION_SECRET: openssl rand -base64 32
# 5. Run: npm install && npm run db:push && npm run dev

# For production deployment:
# 1. Use a managed PostgreSQL service
# 2. Set NODE_ENV=production
# 3. Use secure, unique secrets
# 4. Enable compression and security headers
# 5. Set up proper monitoring and logging